# ============================================================
# 顺丰签到机器人配置文件
# ============================================================
# 复制此文件为 .env，然后填写实际配置
# ============================================================

# ========== 青龙面板配置（必填） ==========
# 青龙面板地址（本机部署用 127.0.0.1）
QL_URL=http://127.0.0.1:5700

# 青龙 Open API 密钥
# 获取方式：系统设置 → 应用设置 → 新建应用 → 勾选环境变量权限
QL_CLIENT_ID=your_client_id_here
QL_CLIENT_SECRET=your_client_secret_here

# 环境变量名（默认 sfsyUrl，一般不用改）
ENV_NAME=sfsyUrl

# ========== WxPusher 配置（微信推送 + 交互） ==========
# WxPusher 应用 Token
# 注册地址：https://wxpusher.zjiecode.com/admin/
WXPUSHER_APP_TOKEN=

# 用户 UID（白名单，多个用逗号分隔）
# 查看方式：WxPusher 后台 → 用户管理 → 复制 UID
WXPUSHER_UIDS=

# 主题 ID（可选，多个用逗号分隔）
WXPUSHER_TOPIC_IDS=

# 管理员 UID（默认为 WXPUSHER_UIDS，有操作权限的用户）
ADMIN_UIDS=

# ========== 企业微信群机器人（可选） ==========
# Webhook 地址（群设置 → 群机器人 → 添加 → 复制 Webhook）
# 示例：https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
WECOM_WEBHOOK=

# ========== 钉钉群机器人（可选） ==========
# Webhook 地址
# 示例：https://oapi.dingtalk.com/robot/send?access_token=xxx
DINGTALK_WEBHOOK=

# 加签密钥（安全设置 → 加签 → 复制密钥）
DINGTALK_SECRET=

# ========== 飞书群机器人（可选） ==========
# Webhook 地址
# 示例：https://open.feishu.cn/open-apis/bot/v2/hook/xxx
FEISHU_WEBHOOK=

# 签名校验密钥（安全设置 → 签名校验）
FEISHU_SECRET=

# ========== 机器人设置 ==========
# 消息轮询间隔（秒），默认 30 秒
POLL_INTERVAL=30

# 每日签到时间（24小时制）
CHECKIN_HOUR=8
CHECKIN_MINUTE=0
