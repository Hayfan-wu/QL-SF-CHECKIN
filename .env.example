# ========== 青龙面板配置 ==========
# 青龙面板地址（本机部署用 127.0.0.1）
QL_URL=http://127.0.0.1:5700

# 青龙 Open API 密钥（系统设置 → 应用设置 → 新建应用）
QL_CLIENT_ID=your_client_id_here
QL_CLIENT_SECRET=your_client_secret_here

# ========== WxPusher 配置 ==========
# WxPusher 应用 Token（https://wxpusher.zjiecode.com/admin/）
WXPUSHER_APP_TOKEN=AT_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 允许操作的用户 UID（白名单，多个用逗号分隔，留空则所有人都能操作）
# 查看 UID：在 WxPusher 后台 → 用户管理 → 复制 UID
WXPUSHER_UIDS=UID_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========== 其他配置 ==========
# 轮询间隔（秒），默认 30 秒
POLL_INTERVAL=30

# 环境变量名（默认 sfsyUrl，一般不用改）
ENV_NAME=sfsyUrl
