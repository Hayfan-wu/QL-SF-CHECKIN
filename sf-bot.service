[Unit]
Description=SF Express Checkin Bot
After=network.target
Wants=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/sf
EnvironmentFile=/root/sf/.env
ExecStart=/usr/bin/python3 /root/sf/sf_bot.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=sf-bot

# 资源限制
MemoryLimit=256M
CPUQuota=30%

[Install]
WantedBy=multi-user.target
